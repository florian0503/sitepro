{% extends 'base.html.twig' %}

{% block title %}Contact - EntryWeb{% endblock %}

{% block body %}
<div data-controller="scroll-animation">
    <section class="page-hero">
        <div class="page-hero-inner">
            <h1 class="page-hero-title swiss-fade-up" data-scroll-animation-target="item">Démarrons votre projet</h1>
            <p class="page-hero-description swiss-fade-up" data-scroll-animation-target="item" data-delay="100">
                Remplissez le formulaire ci-dessous et recevez une réponse personnalisée sous 24h
            </p>
        </div>
    </section>

    <section class="contact-section">
        <div class="contact-container">
            <div class="contact-form-wrapper swiss-fade-up" data-scroll-animation-target="item" data-delay="200">
                {% for message in app.flashes('success') %}
                    {% if message == 'contact_sent' %}
                    <div class="contact-success">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                            <polyline points="22 4 12 14.01 9 11.01"/>
                        </svg>
                        <h3>Message envoyé avec succès !</h3>
                        <p>Merci pour votre message. Nous vous répondrons sous 24h ouvrées.</p>
                        <a href="{{ path('app_home') }}" class="btn-contact-submit">Retour à l'accueil</a>
                    </div>
                    {% endif %}
                {% else %}
                <form class="contact-form" method="post" action="{{ path('app_contact') }}" data-controller="contact-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('contact_form') }}">
                    {% if parrain is defined and parrain %}
                        <div class="parrainage-referral-banner">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="18" cy="5" r="3"></circle>
                                <circle cx="6" cy="12" r="3"></circle>
                                <circle cx="18" cy="19" r="3"></circle>
                                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
                                <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
                            </svg>
                            <span>Parrainé par : <strong>{{ parrain.email }}</strong></span>
                            <input type="hidden" name="referral_code" value="{{ parrain.referralCode }}">
                        </div>
                    {% endif %}
                    <div class="form-group">
                        <label for="name">Nom complet *</label>
                        <input type="text" id="name" name="name" placeholder="Votre nom" required>
                    </div>

                    <div class="form-group">
                        <label for="email">Email *</label>
                        <input type="email" id="email" name="email" placeholder="votre@email.com" required>
                    </div>

                    <div class="form-group" data-controller="custom-select">
                        <label for="budget">Formule souhaitée *</label>
                        <select id="budget" name="budget" required data-custom-select-target="select" {% if preselectedBudget %}data-preselect="{{ preselectedBudget }}"{% endif %}>
                            <option value="">Sélectionnez une formule</option>
                            <option value="pack-essentiel-starter"  {{ selectedOffer == 'pack-essentiel' and selectedSubscription == 'starter'  ? 'selected' : '' }}>Pack Essentiel — Starter (349€HT + 49€HT/mois)</option>
                            <option value="pack-essentiel-confort"  {{ selectedOffer == 'pack-essentiel' and selectedSubscription == 'confort'  ? 'selected' : '' }}>Pack Essentiel — Confort (349€HT + 79€HT/mois)</option>
                            <option value="pack-essentiel-premium"  {{ selectedOffer == 'pack-essentiel' and selectedSubscription == 'premium'  ? 'selected' : '' }}>Pack Essentiel — Premium (349€HT + 99€HT/mois)</option>
                            <option value="pack-business-confort"   {{ selectedOffer == 'pack-business'  and selectedSubscription == 'confort'  ? 'selected' : '' }}>Pack Business — Confort (449€HT + 79€HT/mois)</option>
                            <option value="pack-business-premium"   {{ selectedOffer == 'pack-business'  and selectedSubscription == 'premium'  ? 'selected' : '' }}>Pack Business — Premium (449€HT + 99€HT/mois)</option>
                            <option value="e-commerce-premium"      {{ selectedOffer == 'e-commerce'                                           ? 'selected' : '' }}>E-commerce & Sur-Mesure — Premium (Sur devis + 99€HT/mois)</option>
                            <option value="sur-mesure"              {{ selectedOffer == 'sur-mesure'                                           ? 'selected' : '' }}>Autre projet (Devis personnalisé)</option>
                            <option value="autre"                   {{ selectedOffer == 'autre'                                                ? 'selected' : '' }}>Je ne sais pas encore</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="message">Message</label>
                        <textarea id="message" name="message" rows="5" placeholder="Décrivez votre projet en quelques mots..."></textarea>
                    </div>

                    <div class="form-group form-checkbox">
                        <input type="checkbox" id="rgpd" name="rgpd" required>
                        <label for="rgpd">J'accepte les <a href="{{ path('app_privacy') }}">conditions générales de protection des données</a></label>
                    </div>

                    <button type="submit" class="btn-contact-submit">
                        Envoyer ma demande
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
                        </svg>
                    </button>

                    <p class="form-note">* Champs obligatoires • Réponse garantie sous 24h</p>
                </form>
                {% endfor %}
            </div>

            <aside class="contact-sidebar swiss-fade-up" data-scroll-animation-target="item" data-delay="300">
                <div class="contact-info-card">
                    <h3 class="contact-info-title">Informations de contact</h3>
                    <p class="contact-info-desc">Vous préférez nous contacter directement ? Utilisez l'un des moyens ci-dessous. Nous sommes là pour répondre à toutes vos questions.</p>

                    <div class="contact-info-item">
                        <div class="contact-info-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                        </div>
                        <div class="contact-info-content">
                            <span class="contact-info-label">Email</span>
                            <span class="contact-info-value">contact@entryweb.fr</span>
                        </div>
                    </div>

                    <div class="contact-info-item">
                        <div class="contact-info-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                            </svg>
                        </div>
                        <div class="contact-info-content">
                            <span class="contact-info-label">Téléphone (1er contact)</span>
                            <span class="contact-info-value">06 61 61 79 65</span>
                        </div>
                    </div>

                    <div class="contact-info-item">
                        <div class="contact-info-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <polyline points="12 6 12 12 16 14"/>
                            </svg>
                        </div>
                        <div class="contact-info-content">
                            <span class="contact-info-label">Disponibilité</span>
                            <span class="contact-info-value">Lun-Ven : 9h-18h</span>
                        </div>
                    </div>
                </div>

                <div class="contact-social">
                    <span class="contact-social-label">Suivez-nous</span>
                    <div class="contact-social-links">
                        <a href="https://www.linkedin.com/in/entry-web-a9a3353b2?utm_source=share_via&utm_content=profile&utm_medium=member_ios" class="contact-social-link" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                            </svg>
                        </a>
                        <a href="mailto:contact@entryweb.fr" class="contact-social-link" aria-label="Email">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="4" width="20" height="16" rx="2"/>
                                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                            </svg>
                        </a>
                    </div>
                </div>

                <div class="contact-benefits">
                    <div class="contact-benefit-item">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        <span>Devis gratuit et sans engagement</span>
                    </div>
                    <div class="contact-benefit-item">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        <span>Réponse personnalisée sous 24h</span>
                    </div>
                    <div class="contact-benefit-item">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        <span>Premier échange téléphonique offert</span>
                    </div>
                </div>
            </aside>
        </div>

    </section>
</div>
{% endblock %}
