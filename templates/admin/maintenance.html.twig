{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Mode maintenance{% endblock %}

{% block main %}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'success' ? 'success' : 'warning' }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <div class="card mb-3" style="max-width: 480px;">
        <div class="card-body d-flex align-items-center justify-content-between gap-3">
            <div>
                <strong>Site en maintenance</strong>
                <p class="text-muted mb-0" style="font-size: 13px;">
                    {% if maintenance_active %}
                        Le site est inaccessible aux visiteurs.
                    {% else %}
                        Le site est accessible normalement.
                    {% endif %}
                </p>
            </div>
            <form method="post" action="{{ path('admin_maintenance_toggle') }}" class="mb-0">
                <input type="hidden" name="_token" value="{{ csrf_token('maintenance_toggle') }}">
                <div class="form-check form-switch" style="transform: scale(1.4); transform-origin: right center;">
                    <input
                        class="form-check-input"
                        type="checkbox"
                        role="switch"
                        id="maintenanceSwitch"
                        {{ maintenance_active ? 'checked' : '' }}
                        onchange="this.form.submit()"
                        style="cursor: pointer;"
                    >
                </div>
            </form>
        </div>
    </div>

    <p class="text-muted" style="font-size: 12px;">
        <i class="fa fa-info-circle me-1"></i>
        L'accès <code>/admin</code> reste disponible même en mode maintenance.
    </p>
{% endblock %}
