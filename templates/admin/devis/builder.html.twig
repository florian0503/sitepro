<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Nouveau devis sur mesure - EntryWeb Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <style>
        body { background: #f8f9fa; }
        .top-bar { background: #2563eb; color: #fff; padding: 12px 24px; display: flex; justify-content: space-between; align-items: center; }
        .top-bar a { color: #fff; text-decoration: none; opacity: 0.8; }
        .top-bar a:hover { opacity: 1; }
        .devis-item-row { cursor: pointer; transition: all 0.15s; }
        .devis-item-row:hover { border-color: #2563eb !important; }
        .devis-item-row.selected { border-color: #2563eb !important; background: #eef2ff !important; }
        .sticky-summary { position: sticky; top: 20px; }
    </style>
</head>
<body>
<div class="top-bar">
    <div><strong>EntryWeb Admin</strong> &mdash; Nouveau devis sur mesure</div>
    <a href="{{ path('admin') }}"><i class="fa fa-arrow-left me-1"></i> Retour à l'admin</a>
</div>

<div class="container-fluid py-4 px-4">
<form method="post" action="/devis/builder" id="devis-form">
    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header bg-white">
                    <h5 class="card-title mb-0"><i class="fa fa-user me-2"></i>Informations client</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label" for="client_first_name">Prénom <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="client_first_name" name="client_first_name" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="client_last_name">Nom <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="client_last_name" name="client_last_name" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="client_email">Email <span class="text-danger">*</span></label>
                            <input type="email" class="form-control" id="client_email" name="client_email" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="client_phone">Téléphone</label>
                            <input type="text" class="form-control" id="client_phone" name="client_phone">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="client_company">Entreprise</label>
                            <input type="text" class="form-control" id="client_company" name="client_company">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="client_siret">SIRET</label>
                            <input type="text" class="form-control" id="client_siret" name="client_siret">
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="client_address">Adresse</label>
                            <input type="text" class="form-control" id="client_address" name="client_address">
                        </div>
                    </div>
                </div>
            </div>

            <h4 class="mb-3"><i class="fa fa-list-check me-2"></i>Prestations</h4>

            {% for category in categories %}
            <div class="card mb-3">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="card-title mb-0 fw-bold">{{ category.name }}</h6>
                    <span class="badge bg-secondary category-subtotal" data-category="{{ loop.index0 }}">0,00 €</span>
                </div>
                <div class="card-body p-2">
                    {% for item in category.items %}
                    {% set item_key = loop.parent.loop.index0 ~ '_' ~ loop.index0 %}
                    <div class="form-check devis-item-row m-0 p-3 border-bottom" style="padding-left: 2.5rem !important;">
                        <input class="form-check-input devis-checkbox"
                               type="checkbox"
                               name="items[]"
                               value="{{ item_key }}"
                               id="item_{{ item_key }}"
                               data-price="{{ item.price }}"
                               data-monthly="{{ item.isMonthly ? '1' : '0' }}"
                               data-category="{{ loop.parent.loop.index0 }}">
                        <label class="form-check-label w-100" for="item_{{ item_key }}">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <strong>{{ item.name }}</strong>
                                    <div class="text-muted small">{{ item.description }}</div>
                                </div>
                                <span class="badge bg-primary ms-3 text-nowrap fs-6">
                                    {{ item.price|number_format(0, ',', ' ') }} € HT{% if item.isMonthly %} /mois{% endif %}
                                </span>
                            </div>
                        </label>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endfor %}

            <div class="card mb-4">
                <div class="card-header bg-white">
                    <h5 class="card-title mb-0"><i class="fa fa-comment me-2"></i>Notes / Commentaires</h5>
                </div>
                <div class="card-body">
                    <textarea class="form-control" name="notes" rows="3" placeholder="Remarques, conditions particulières..."></textarea>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="sticky-summary">
                <div class="card border-primary">
                    <div class="card-header bg-primary text-white">
                        <h5 class="card-title mb-0 text-white"><i class="fa fa-calculator me-2"></i>Récapitulatif</h5>
                    </div>
                    <div class="card-body">
                        <div id="selected-items-list" class="mb-3">
                            <p class="text-muted mb-0" id="no-selection">Aucune prestation sélectionnée</p>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-2 fs-5">
                            <strong>Total HT</strong>
                            <strong class="text-primary"><span id="total-ht">0,00</span> €</strong>
                        </div>
                        <div class="mt-1"><small class="text-muted">TVA non applicable, art. 293 B du CGI</small></div>
                        <div><small class="text-muted">Validité : 7 jours</small></div>
                        <div id="monthly-section" style="display:none;" class="alert alert-warning py-2 mb-3">
                            <small><strong>+ Abonnement :</strong> <span id="total-monthly">0,00</span> € /mois</small>
                        </div>
                        <hr>
                        <button type="submit" class="btn btn-primary w-100 btn-lg">
                            <i class="fa fa-file-invoice me-1"></i> Créer le devis
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
</div>

{{ importmap('devis-builder') }}
</body>
</html>
