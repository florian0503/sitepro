{% extends 'base.html.twig' %}

{% block title %}Page non trouvée — EntryWeb{% endblock %}

{% block body %}
<section class="error-page">
    <div class="error-container">

        <div class="error-visual">
            <svg viewBox="0 0 180 180" fill="none" xmlns="http://www.w3.org/2000/svg">
                <!-- Planète -->
                <circle cx="90" cy="110" r="48" fill="#eff6ff" stroke="#dbeafe" stroke-width="1.5"/>
                <ellipse cx="90" cy="110" rx="48" ry="14" fill="none" stroke="#93c5fd" stroke-width="1.5" stroke-dasharray="6 4"/>
                <!-- Astronaute corps -->
                <rect x="72" y="52" width="36" height="40" rx="8" fill="#e0e7ff" stroke="#818cf8" stroke-width="1.5"/>
                <!-- Visière -->
                <rect x="78" y="30" width="24" height="28" rx="12" fill="#dbeafe" stroke="#60a5fa" stroke-width="1.5"/>
                <rect x="82" y="36" width="16" height="16" rx="8" fill="white" opacity="0.7"/>
                <!-- Bras -->
                <path d="M72 64 Q58 60 56 72" stroke="#818cf8" stroke-width="3" stroke-linecap="round"/>
                <path d="M108 64 Q122 60 124 72" stroke="#818cf8" stroke-width="3" stroke-linecap="round"/>
                <!-- Jambes -->
                <path d="M82 92 L78 108" stroke="#818cf8" stroke-width="3" stroke-linecap="round"/>
                <path d="M98 92 L102 108" stroke="#818cf8" stroke-width="3" stroke-linecap="round"/>
                <!-- Étoiles -->
                <circle cx="24" cy="28" r="2.5" fill="#bfdbfe"/>
                <circle cx="156" cy="20" r="2" fill="#bfdbfe"/>
                <circle cx="148" cy="60" r="1.5" fill="#93c5fd"/>
                <circle cx="32" cy="80" r="1.5" fill="#93c5fd"/>
                <circle cx="60" cy="16" r="1.5" fill="#bfdbfe"/>
                <circle cx="130" cy="38" r="2" fill="#bfdbfe"/>
                <!-- Signal perdu -->
                <path d="M116 44 Q128 36 136 44" stroke="#60a5fa" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.5"/>
                <path d="M120 38 Q132 26 144 38" stroke="#93c5fd" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.35"/>
            </svg>
        </div>

        <div class="error-content">
            <span class="error-code">Erreur 404</span>
            <h1 class="error-title">Cette page s'est perdue dans l'espace</h1>
            <p class="error-description">
                La page que vous cherchez n'existe pas ou a été déplacée.<br>
                Pas d'inquiétude, repartez d'ici.
            </p>
            <div class="error-actions">
                <a href="{{ path('app_home') }}" class="btn btn-lg btn-primary">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                    Retour à l'accueil
                </a>
                <a href="{{ path('app_contact') }}" class="btn btn-lg btn-outline">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
                    </svg>
                    Nous contacter
                </a>
            </div>
        </div>

        <div class="error-divider"></div>

        <nav class="error-links" aria-label="Liens utiles">
            <a href="{{ path('app_offers') }}" class="error-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 18 15 12 9 6"/>
                </svg>
                Nos offres
            </a>
            <a href="{{ path('app_portfolio') }}" class="error-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 18 15 12 9 6"/>
                </svg>
                Portfolio
            </a>
            <a href="{{ path('app_about') }}" class="error-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 18 15 12 9 6"/>
                </svg>
                À propos
            </a>
            <a href="{{ path('app_faq') }}" class="error-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 18 15 12 9 6"/>
                </svg>
                FAQ
            </a>
        </nav>

    </div>
</section>
{% endblock %}
